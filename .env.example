# ─── Database ───────────────────────────────────────────────────────────────
# "development" uses SQLite, "production" uses MySQL/MariaDB
NODE_ENV=development

# SQLite (development)
DATABASE_URL="file:./dev.db"

# MySQL/MariaDB (production) – comment out DATABASE_URL above and use this:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENCLAW_WEBHOOK_SECRET=

# ─── IDX (TREB) ──────────────────────────────────────────────────────────────
IDX_API_BASE_URL=https://api.idx.broker/api/1.7
IDX_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
