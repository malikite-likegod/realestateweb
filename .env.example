# ─── Database ───────────────────────────────────────────────────────────────
# "development" uses SQLite, "production" uses PostgreSQL
NODE_ENV=development

# SQLite (development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) – comment out DATABASE_URL above and use this:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/realestateweb"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
# JWT expiry for contact portal sessions
CONTACT_JWT_EXPIRES_IN=30d

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENCLAW_WEBHOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Agent / Branding ────────────────────────────────────────────────────────
AGENT_NAME=
AGENT_EMAIL=
AGENT_PHONE=

# ─── Amplify TREB/AMPRE ────────────────────────────────────────────────────────
# For local dev, mock Amplify API runs inside Next.js — no external service needed.
# Production: remove AMPRE_API_BASE_URL and set real tokens below.
AMPRE_IDX_TOKEN=mock-idx-token
AMPRE_DLA_TOKEN=mock-dla-token
AMPRE_VOX_TOKEN=mock-vox-token
# Local dev only — points to the mock. Omit in production.
AMPRE_API_BASE_URL=http://localhost:3000/api/mock-reso
# Cron authentication (unchanged)
RESO_SYNC_SECRET=change-me-in-production
# Brokerage filter — set AMPRE_OFFICE_KEY to your ListOfficeKey value to filter
# listings server-side (faster than client-side name matching).
# Find your key: SELECT DISTINCT "listOfficeKey", "listOfficeName" FROM reso_properties LIMIT 20;
# AMPRE_OFFICE_KEY=
# Fallback name filter (client-side) — used when AMPRE_OFFICE_KEY is not set
# AMPRE_BROKERAGE_NAME=

# Local AI (Ollama) — required if using MLS listing descriptions
# Install Ollama: https://ollama.ai and run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── IMAP Inbox Sync ─────────────────────────────────────────────────────────
# Polls this mailbox for inbound replies and logs them against contacts in CRM.
# Hostinger: imap.hostinger.com port 993
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
# IMAP_MAILBOX=INBOX

# ─── SMS / Twilio (optional) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Email validation (optional) ─────────────────────────────────────────────
ZEROBOUNCE_API_KEY=

# ─── Automation runner ───────────────────────────────────────────────────────
# Set to 'true' to enable background automation processing
ENABLE_AUTOMATION_RUNNER=false
# Interval in ms between automation job checks (default: 60000)
AUTOMATION_INTERVAL_MS=60000
# Secret for the automation process endpoint
AUTOMATION_PROCESS_SECRET=change-me-in-production

# ─── Data retention cron ─────────────────────────────────────────────────────
# Run daily: POST /api/admin/purge?type=retention
# Header: x-cron-secret: <RESO_SYNC_SECRET value>

# ─── Internal API secret ─────────────────────────────────────────────────────
# Used by middleware to authenticate the internal /api/internal/blocked-ips endpoint.
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=REPLACE_WITH_RANDOM_SECRET_openssl_rand_-hex_32
