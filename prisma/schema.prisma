// Prisma schema — dual SQLite (dev) / MySQL (prod)
// Switch via DATABASE_URL + provider env var

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // "sqlite" | "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // admin | agent | viewer
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apiKeys           ApiKey[]
  aiJobs            AiJob[]
  tasks             Task[]             @relation("AssignedTasks")
  createdTasks      Task[]             @relation("CreatedTasks")
  activities        Activity[]
  notes             Note[]
  callLogs          CallLog[]
  smsMessages       SmsMessage[]
  emailMessages     EmailMessage[]
  assignedDeals     Deal[]             @relation("AssignedDeals")
  stageHistoryMoves DealStageHistory[] @relation("StageHistoryMover")

  @@map("users")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  prefix      String    // first 8 chars for display
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("api_keys")
}

// ─── Contacts / CRM ───────────────────────────────────────────────────────────

model Contact {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String?  @unique
  phone        String?
  company      String?
  jobTitle     String?
  avatarUrl    String?
  source       String?  // web, referral, idx, manual
  status       String   @default("lead") // lead | prospect | client | past_client
  leadScore    Int      @default(0)
  birthday     DateTime?
  notes        String?
  address      String?
  city         String?
  province     String?
  postalCode   String?
  country      String   @default("CA")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tags              ContactTag[]
  deals             DealParticipant[]
  activities        Activity[]
  tasks             Task[]
  showings          Showing[]
  notesList         Note[]
  relationships     ContactRelationship[] @relation("ContactA")
  relatedTo         ContactRelationship[] @relation("ContactB")
  behaviorEvents    BehaviorEvent[]
  leadScoreHistory  LeadScore[]
  callLogs          CallLog[]
  smsMessages       SmsMessage[]
  emailMessages     EmailMessage[]
  campaignEnrollments CampaignEnrollment[]

  @@map("contacts")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6366f1")
  contacts  ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model ContactRelationship {
  id         String  @id @default(cuid())
  contactAId String
  contactBId String
  type       String  // spouse, partner, colleague, referral
  contactA   Contact @relation("ContactA", fields: [contactAId], references: [id])
  contactB   Contact @relation("ContactB", fields: [contactBId], references: [id])

  @@map("contact_relationships")
}

// ─── Deals / Pipeline ─────────────────────────────────────────────────────────

model Stage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  color      String   @default("#6366f1")
  isDefault  Boolean  @default(false)
  deals      Deal[]
  history    DealStageHistory[]

  @@map("stages")
}

model Deal {
  id            String    @id @default(cuid())
  title         String
  value         Float?
  currency      String    @default("CAD")
  stageId       String
  stage         Stage     @relation(fields: [stageId], references: [id])
  assigneeId    String?                         // agent responsible for this deal
  assignee      User?     @relation("AssignedDeals", fields: [assigneeId], references: [id])
  closedAt      DateTime?
  expectedClose DateTime?
  probability   Int       @default(50)
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants  DealParticipant[]
  activities    Activity[]
  tasks         Task[]
  showings      Showing[]
  stageHistory  DealStageHistory[]

  @@map("deals")
}

// DealStageHistory: immutable log of every stage a deal has passed through.
// enteredAt is set when the deal moves into the stage; exitedAt when it leaves.
// Used to calculate time-in-stage and conversion metrics.
model DealStageHistory {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id])
  enteredAt DateTime @default(now())
  exitedAt  DateTime?
  movedById String?
  movedBy   User?    @relation("StageHistoryMover", fields: [movedById], references: [id])

  @@map("deal_stage_history")
}

model DealParticipant {
  dealId    String
  contactId String
  role      String   @default("buyer") // buyer | seller | agent | lawyer
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@id([dealId, contactId])
  @@map("deal_participants")
}

// ─── Properties / Listings ────────────────────────────────────────────────────

model Property {
  id              String   @id @default(cuid())
  mlsNumber       String?  @unique
  title           String
  description     String?
  status          String   @default("active") // active | sold | expired | draft
  listingType     String   @default("sale")   // sale | rent | lease
  propertyType    String   @default("detached") // detached | semi | condo | townhouse | commercial
  price           Float
  priceUnit       String   @default("CAD")
  bedrooms        Int?
  bathrooms       Float?
  parkingSpaces   Int?
  sqft            Int?
  lotSize         Float?
  lotSizeUnit     String   @default("sqft")
  yearBuilt       Int?
  address         String
  city            String
  province        String   @default("ON")
  postalCode      String?
  country         String   @default("CA")
  latitude        Float?
  longitude       Float?
  images          String?  // JSON array of URLs
  features        String?  // JSON array of strings
  virtualTourUrl  String?
  openHouseDate   DateTime?
  listedAt        DateTime?
  soldAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deals    Deal[]
  showings Showing[]
  listings Listing[]

  @@map("properties")
}

model Listing {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  publishedAt DateTime?
  featured    Boolean  @default(false)
  slug        String   @unique
  metaTitle   String?
  metaDesc    String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("listings")
}

// ─── IDX ──────────────────────────────────────────────────────────────────────

model IdxProperty {
  id              String    @id @default(cuid())
  idxId           String    @unique // IDX provider's ID
  mlsNumber       String?
  status          String    @default("active")
  propertyType    String?
  listingType     String    @default("sale")
  price           Float?
  bedrooms        Int?
  bathrooms       Float?
  sqft            Int?
  address         String?
  city            String?
  province        String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  description     String?
  images          String?   // JSON array
  features        String?   // JSON array
  listedAt        DateTime?
  lastSyncedAt    DateTime  @default(now())
  rawData         String?   // full JSON from IDX feed

  @@map("idx_properties")
}

model IdxUpdate {
  id         String   @id @default(cuid())
  syncedAt   DateTime @default(now())
  added      Int      @default(0)
  updated    Int      @default(0)
  removed    Int      @default(0)
  errors     String?
  duration   Int?     // ms

  @@map("idx_updates")
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // todo | in_progress | done | cancelled
  priority    String    @default("normal") // low | normal | high | urgent
  dueAt       DateTime?
  completedAt DateTime?
  assigneeId  String?
  assignee    User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?     @relation("CreatedTasks", fields: [createdById], references: [id])
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tasks")
}

// ─── Activities ───────────────────────────────────────────────────────────────

model Activity {
  id          String   @id @default(cuid())
  type        String   // call | email | meeting | note | showing | task | deal_change
  subject     String?
  body        String?
  outcome     String?
  durationMin Int?
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("activities")
}

model Note {
  id        String   @id @default(cuid())
  body      String
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

// ─── Showings ─────────────────────────────────────────────────────────────────

model Showing {
  id         String    @id @default(cuid())
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  scheduledAt DateTime
  status     String    @default("scheduled") // scheduled | completed | cancelled
  notes      String?
  createdAt  DateTime  @default(now())

  @@map("showings")
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String
  coverImage  String?
  status      String    @default("draft") // draft | published | archived
  publishedAt DateTime?
  authorName  String?
  metaTitle   String?
  metaDesc    String?
  tags        String?   // JSON array
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─── Landing Pages ────────────────────────────────────────────────────────────

model LandingPage {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  content    String    // JSON blocks
  status     String    @default("draft")
  publishedAt DateTime?
  views      Int       @default(0)
  leads      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  leadMagnets LeadMagnet[]

  @@map("landing_pages")
}

model LeadMagnet {
  id            String      @id @default(cuid())
  title         String
  type          String      // ebook | report | guide | checklist
  fileUrl       String?
  landingPageId String?
  landingPage   LandingPage? @relation(fields: [landingPageId], references: [id])
  downloads     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@map("lead_magnets")
}

// ─── Automation ───────────────────────────────────────────────────────────────

model AutomationSequence {
  id          String   @id @default(cuid())
  name        String
  description String?
  trigger     String   // new_lead | deal_stage_change | showing_scheduled | manual
  isActive    Boolean  @default(true)
  steps       AutomationStep[]
  enrollments CampaignEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("automation_sequences")
}

model AutomationStep {
  id           String             @id @default(cuid())
  sequenceId   String
  sequence     AutomationSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order        Int
  type         String             // send_email | send_sms | create_task | wait | update_lead_score
  config       String             // JSON: { subject, body, templateId, taskTitle, priority, scoreDelta }
  delayMinutes Int                @default(0)
  createdAt    DateTime           @default(now())

  executions   CampaignStepExecution[]

  @@map("automation_steps")
}

// CampaignEnrollment: tracks a contact's position inside an AutomationSequence.
// nextRunAt drives when the background processor should advance to the next step.
model CampaignEnrollment {
  id          String             @id @default(cuid())
  sequenceId  String
  sequence    AutomationSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      String             @default("active") // active | paused | completed | cancelled
  currentStep Int                @default(0)        // index of next step to execute
  nextRunAt   DateTime?                             // when to process next step
  enrolledAt  DateTime           @default(now())
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  executions  CampaignStepExecution[]

  @@unique([sequenceId, contactId])               // one active enrollment per campaign per contact
  @@map("campaign_enrollments")
}

// CampaignStepExecution: immutable audit log for every step that ran.
model CampaignStepExecution {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   CampaignEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId       String
  step         AutomationStep     @relation(fields: [stepId], references: [id])
  status       String             @default("pending") // pending | completed | failed | skipped
  result       String?            // JSON summary of what happened
  ranAt        DateTime?
  createdAt    DateTime           @default(now())

  @@map("campaign_step_executions")
}

// AutomationRule: event-triggered rules that fire one-time actions.
// Unlike sequences (ongoing drips), rules react immediately to a single trigger.
// conditions and actions are stored as JSON arrays.
//
// Example conditions: [{ "field": "leadScore", "op": "gte", "value": 70 }]
// Example actions:    [{ "type": "assign_task", "title": "Call hot lead", "priority": "high" }]
model AutomationRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  trigger     String    // new_lead | deal_stage_changed | lead_inactive | listing_viewed | manual
  conditions  String?   // JSON array of condition objects
  actions     String    // JSON array of action objects
  isActive    Boolean   @default(true)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("automation_rules")
}

// JobQueue: database-backed background job queue.
// The processor at /api/automation/process picks up pending jobs whose
// runAt <= now() and executes them, respecting maxAttempts on failure.
model JobQueue {
  id          String    @id @default(cuid())
  type        String    // send_email_job | send_sms_job | execute_campaign_step | evaluate_rules
  payload     String    // JSON with all data the handler needs
  status      String    @default("pending") // pending | running | completed | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAt       DateTime  @default(now())    // earliest time to execute
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@map("job_queue")
}

// ─── Communications ───────────────────────────────────────────────────────────
// CallLog: stores manually-logged and provider-recorded calls per contact.
// Twilio integration fields (twilioCallSid, recordingUrl, transcription) are
// populated automatically when the Twilio provider is configured.

model CallLog {
  id             String   @id @default(cuid())
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction      String   @default("outbound") // inbound | outbound
  status         String   @default("completed") // completed | missed | voicemail | failed
  durationSec    Int?
  notes          String?
  recordingUrl   String?  // optional link to stored recording
  transcription  String?  // AI or provider transcription text
  fromNumber     String?
  toNumber       String?
  twilioCallSid  String?  // Twilio Call SID; null until provider is connected
  loggedById     String?
  loggedBy       User?    @relation(fields: [loggedById], references: [id])
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@map("call_logs")
}

// SmsMessage: individual SMS/MMS messages in a conversation thread per contact.
// groupId links messages that belong to the same group-text broadcast.
model SmsMessage {
  id          String   @id @default(cuid())
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction   String   @default("outbound") // inbound | outbound
  status      String   @default("sent")     // queued | sent | delivered | failed | received
  body        String
  fromNumber  String?
  toNumber    String?
  mediaUrls   String?  // JSON array of MMS media attachment URLs
  groupId     String?  // shared UUID for group-text threads
  twilioSid   String?  // Twilio Message SID
  sentById    String?
  sentBy      User?    @relation(fields: [sentById], references: [id])
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("sms_messages")
}

// EmailMessage: sent and received emails attached to a contact.
// trackingId enables server-side open/click tracking via a 1×1 pixel endpoint.
model EmailMessage {
  id          String         @id @default(cuid())
  contactId   String?
  contact     Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction   String         @default("outbound") // inbound | outbound
  status      String         @default("sent") // draft | sent | delivered | bounced | failed
  subject     String
  body        String         // HTML content
  fromEmail   String?
  toEmail     String?
  ccEmails    String?        // JSON array of CC addresses
  templateId  String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  openedAt    DateTime?      // timestamp of first open
  clickedAt   DateTime?      // timestamp of first tracked click
  openCount   Int            @default(0)
  clickCount  Int            @default(0)
  trackingId  String?        @unique // random token for pixel tracking
  sentById    String?
  sentBy      User?          @relation(fields: [sentById], references: [id])
  sentAt      DateTime       @default(now())
  createdAt   DateTime       @default(now())

  @@map("email_messages")
}

// EmailTemplate: reusable HTML templates with {{variable}} placeholders.
// Used by the email composer and drip campaign steps.
model EmailTemplate {
  id        String         @id @default(cuid())
  name      String
  subject   String
  body      String         // HTML with {{firstName}}, {{agentName}}, etc.
  category  String?        // follow_up | listing | newsletter | custom
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  emails    EmailMessage[]

  @@map("email_templates")
}

// ─── Analytics / Tracking ─────────────────────────────────────────────────────

model VisitorLog {
  id          String   @id @default(cuid())
  sessionId   String?
  ip          String?
  userAgent   String?
  referer     String?
  page        String
  contactId   String?
  occurredAt  DateTime @default(now())

  @@map("visitor_logs")
}

model BehaviorEvent {
  id          String   @id @default(cuid())
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  sessionId   String?
  eventType   String   // page_view | listing_view | blog_read | form_submit | search
  entityId    String?  // listing id, blog post id, etc.
  metadata    String?  // JSON
  occurredAt  DateTime @default(now())

  @@map("behavior_events")
}

model LeadScore {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])
  score     Int
  delta     Int
  reason    String?
  createdAt DateTime @default(now())

  @@map("lead_scores")
}

model PropertySearchLog {
  id         String   @id @default(cuid())
  sessionId  String?
  contactId  String?
  query      String   // JSON of filters used
  results    Int      @default(0)
  occurredAt DateTime @default(now())

  @@map("property_search_logs")
}

// ─── AI ───────────────────────────────────────────────────────────────────────

model AiJob {
  id         String    @id @default(cuid())
  type       String    // lead_scoring | blog_generation | listing_description | market_analysis | buyer_intent
  status     String    @default("pending") // pending | running | completed | failed
  input      String    // JSON
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime  @default(now())

  result AiResult?

  @@map("ai_jobs")
}

model AiResult {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       AiJob    @relation(fields: [jobId], references: [id])
  output    String   // JSON or plain text
  tokensUsed Int?
  model     String?
  createdAt DateTime @default(now())

  @@map("ai_results")
}

model AiCommandLog {
  id          String   @id @default(cuid())
  command     String   // create_task | log_activity | update_lead_score | etc.
  payload     String   // JSON input
  response    String?  // JSON output
  status      String   @default("success") // success | error
  apiKeyId    String?
  ipAddress   String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@map("ai_command_logs")
}
